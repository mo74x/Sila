# Your unique tenant identifier (UUID)
TENANT_ID=

# WebSocket URL of the Sila cloud gateway
CLOUD_WS_URL=wss://api.sila.dev

# PIN for the USB token (EgyptTrust ePass2003)
TOKEN_PIN=

# Path to the PKCS#11 driver DLL (default is correct for EgyptTrust on Windows)
DLL_PATH=C:\Windows\System32\eps2003csp11.dll
